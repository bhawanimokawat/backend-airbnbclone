<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/output.css">
</head>

<body>
    <%- include('../partials/header') %>

        <main class="mx-auto mt-10 max-w-4xl px-4">
            <div class="overflow-hidden rounded-2xl bg-white shadow-lg">
                <img src="<%= home.image %>" alt="<%= home.houseName %>" class="h-72 w-full object-cover">

                <div class="p-6">
                    <p class="text-sm font-semibold uppercase tracking-wide text-red-500">
                        <%= home.location || home.loaction %>
                    </p>

                    <h1 class="mt-2 text-3xl font-bold text-gray-900">
                        <%= home.houseName %>
                    </h1>

                    <div class="mt-4 flex items-center justify-between">
                        <p class="text-xl font-bold text-gray-900">
                            Rs<%= home.price %>
                                <span class="text-sm font-normal text-gray-500">/ night</span>
                        </p>

                        <p class="rounded-full bg-yellow-100 px-4 py-2 font-semibold text-gray-800">
                            ⭐ <%= home.rating %>
                        </p>
                    </div>
                    <%- include('../partials/Favourite') %>
                        <div class="flex items-center gap-3 mt-4">
                            <form action="/bookings/add" method="POST">

                                <input type="hidden" name="homeId" value="<%= home._id %>">

                                <button class="bg-green-500 text-white px-4 py-2 rounded hover:bg-green-600">
                                    Book Now
                                </button>

                            </form>
                        </div>
                </div>


        </main>
</body>

</html>