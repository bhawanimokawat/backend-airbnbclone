<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/output.css">
</head>

<body>
    <%- include('../partials/header') %>

        <main class="container mx-auto bg-white shadow-lg rounded-lg p-8 mt-10 max-w-6xl">
            <h1 class="text-3xl text-red-500 font-bold text-center mb-6">
                Your favourite homes
            </h1>

            <% if (!favouriteHomes || favouriteHomes.length===0) { %>
                <p class="text-center text-gray-600">No favourite homes added yet.</p>
                <% } else { %>
                    <div class="flex flex-wrap justify-center gap-6">
                        <% favouriteHomes.forEach(home=> { %>
                            <div
                                class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition duration-300 w-full max-w-sm">
                                <img src="<%= home.image %>" alt="<%= home.houseName %>"
                                    class="w-full h-48 object-cover" />
                                <div class="p-4">
                                    <h3 class="text-xl font-semibold text-gray-800 mb-2">
                                        <%= home.houseName %>
                                    </h3>
                                    <p class="text-gray-600 mb-2">
                                        <%= home.location || home.loaction %>
                                    </p>
                                    <div class="flex justify-between items-center mb-2">
                                        <span class="text-lg font-bold text-red-500">Rs<%= home.price %> / night</span>
                                        <span class="text-gray-700">
                                            <%= home.rating %>
                                        </span>
                                    </div>
                                </div>
                                <div class="flex items-center gap-3 mt-3">

                                    <a href="/homes/<%= home._id %>"
                                        class="inline-block rounded-lg bg-blue-500 px-4 py-2 text-white font-medium hover:bg-blue-600 transition shadow-sm">
                                        Details
                                    </a>

                                    <form action="/favourites/delete/<%= home._id %>" method="POST">
                                        <button type="submit"
                                            class="rounded-lg bg-red-500 px-4 py-2 text-white font-medium hover:bg-red-600 transition shadow-sm">
                                            Remove
                                        </button>
                                    </form>

                                </div>
                            </div>
                            <% }) %>
                    </div>
                    <% } %>
        </main>
</body>

</html>