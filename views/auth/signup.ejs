<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
     <link rel="stylesheet" href="/output.css">
</head>
<body>
    <div class="min-h-screen bg-gradient-to-br from-rose-100 via-white to-blue-100 flex items-center justify-center px-4">

    <div class="w-full max-w-2xl bg-white shadow-xl rounded-3xl p-8">

        <div class="text-center mb-8">
            <h1 class="text-4xl font-bold text-gray-800">
                Create Account
            </h1>
            <p class="text-gray-500 mt-2">
                Join Airbnb and start your journey
            </p>
        </div>

        <form action="/signup" method="POST" class="space-y-5">

            <!-- Name Fields -->
            <div class="grid md:grid-cols-2 gap-4">
                <div>
                    <label class="block mb-2 font-medium text-gray-700">
                        First Name
                    </label>
                    <input
                        type="text"
                        name="firstName"
                        placeholder="Enter first name"
                        required
                        class="w-full px-4 py-3 border rounded-xl focus:ring-2 focus:ring-rose-400 outline-none">
                </div>

                <div>
                    <label class="block mb-2 font-medium text-gray-700">
                        Last Name
                    </label>
                    <input
                        type="text"
                        name="lastName"
                        placeholder="Enter last name"
                        required
                        class="w-full px-4 py-3 border rounded-xl focus:ring-2 focus:ring-rose-400 outline-none">
                </div>
            </div>

            <!-- Email -->
            <div>
                <label class="block mb-2 font-medium text-gray-700">
                    Email Address
                </label>
                <input
                    type="email"
                    name="email"
                    placeholder="example@gmail.com"
                    required
                    class="w-full px-4 py-3 border rounded-xl focus:ring-2 focus:ring-rose-400 outline-none">
            </div>

            <!-- Password -->
            <div>
                <label class="block mb-2 font-medium text-gray-700">
                    Password
                </label>
                <input
                    type="password"
                    name="password"
                    placeholder="Create password"
                    required
                    class="w-full px-4 py-3 border rounded-xl focus:ring-2 focus:ring-rose-400 outline-none">
            </div>

            <!-- Confirm Password -->
            <div>
                <label class="block mb-2 font-medium text-gray-700">
                    Confirm Password
                </label>
                <input
                    type="password"
                    name="confirmPassword"
                    placeholder="Confirm password"
                    required
                    class="w-full px-4 py-3 border rounded-xl focus:ring-2 focus:ring-rose-400 outline-none">
            </div>

            <!-- User Type -->
            <div>
                <label class="block mb-3 font-medium text-gray-700">
                    Register As
                </label>

                <div class="grid grid-cols-2 gap-4">

                    <label class="border rounded-xl p-4 cursor-pointer hover:border-rose-500">
                        <input
                            type="radio"
                            name="role"
                            value="guest"
                            checked
                            class="mr-2">
                        Guest
                    </label>

                    <label class="border rounded-xl p-4 cursor-pointer hover:border-rose-500">
                        <input
                            type="radio"
                            name="role"
                            value="host"
                            class="mr-2">
                        Host
                    </label>

                </div>
            </div>

            <!-- Terms -->
            <div class="flex items-center">
                <input
                    type="checkbox"
                    required
                    class="mr-2">
                <span class="text-sm text-gray-600">
                    I agree to the Terms & Conditions
                </span>
            </div>

            <!-- Submit -->
            <button
                type="submit"
                class="w-full bg-rose-600 text-white py-3 rounded-xl font-semibold hover:bg-rose-700 transition">
                Create Account
            </button>

        </form>

        <!-- Login Link -->
        <div class="text-center mt-6">
            <p class="text-gray-600">
                Already have an account?
                <a
                    href="/login"
                    class="text-rose-600 font-semibold hover:underline">
                    Login
                </a>
            </p>
        </div>

    </div>

</div>
</body>
</html>