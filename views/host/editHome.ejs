<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Home</title>
    <link rel="stylesheet" href="/output.css">
</head>

<body class="bg-gradient-to-br from-amber-50 to-orange-100 min-h-screen">

    <!-- Navbar -->
    <%- include('../partials/header') %>

    <!-- Form Section -->
    <div class="flex items-center justify-center px-4 py-12">

        <div class="bg-white w-full max-w-lg rounded-2xl shadow-xl p-8">

            <div class="text-center mb-8">
                <div class="text-5xl mb-3">🏠</div>

                <h1 class="text-3xl font-bold text-gray-800">
                    <%= editing ? "Edit": "Register"%>
                    
                     Your Airbnb Home
                </h1>

                <p class="text-gray-500 mt-2">
                    Add your property and start hosting guests.
                </p>
            </div>

           <form action="<%= editing ? '/edit-home' : '/host/add-home' %>" method="POST">
               <input type="hidden" name="id" value="<%= editing ? home._id : '' %>">

                

    <!-- House Name -->
    <div>
        <label for="houseName" class="block mb-2 font-medium text-gray-700">
            🏠 House Name
        </label>
        <input
            type="text"
            id="houseName"
            value="<%= editing ? home.houseName : ''%>"
            name="houseName"
            placeholder="e.g. Sunset Villa"
            required
            class="w-full px-4 py-3 border rounded-xl focus:ring-2 focus:ring-rose-500 focus:outline-none"
        >
    </div>

    <!-- Price & Rating -->
    <div class="grid md:grid-cols-2 gap-4">

        <div>
            <label for="price" class="block mb-2 font-medium text-gray-700">
                💰 Price Per Night
            </label>
            <input
                type="number"
                 value="<%= editing ? home.price: ''%>"
                id="price"
                name="price"
                placeholder="100"
                required
                class="w-full px-4 py-3 border rounded-xl focus:ring-2 focus:ring-rose-500 focus:outline-none"
            >
        </div>

        <div>
            <label for="rating" class="block mb-2 font-medium text-gray-700">
                ⭐ Rating
            </label>
            <input
                type="number"
                id="rating"
                 value="<%= editing ? home.rating: ''%>"
                name="rating"
                min="1"
                max="5"
                step="0.1"
                placeholder="4.8"
                required
                class="w-full px-4 py-3 border rounded-xl focus:ring-2 focus:ring-rose-500 focus:outline-none"
            >
        </div>

    </div>

    <!-- Location -->
    <div>
        <label for="location" class="block mb-2 font-medium text-gray-700">
            📍 Location
        </label>
        <input
            type="text"
            id="location"
             value="<%= editing ? home.location: ''%>"
            name="location"
            placeholder="e.g. Mandawa, Rajasthan"
            required
            class="w-full px-4 py-3 border rounded-xl focus:ring-2 focus:ring-rose-500 focus:outline-none"
        >
    </div>

    <!-- Image URL -->
    <div>
        <label for="image" class="block mb-2 font-medium text-gray-700">
            🖼️ Image URL
        </label>
        <input
            type="url"
            id="image"
             value="<%= editing ? home.image: ''%>"
            name="image"
            placeholder="https://example.com/home.jpg"
            required
            class="w-full px-4 py-3 border rounded-xl focus:ring-2 focus:ring-rose-500 focus:outline-none"
        >
    </div>
    <!-- Submit Button -->
    <button
        type="submit"
        class="w-full bg-rose-500 py-3 rounded-xl font-semibold hover:bg-rose-600 transition shadow-lg"
    >
         <%= editing ? "upadate Home" : "Add Home" %>
    </button>

</form>
        </div>

    </div>

</body>
</html>